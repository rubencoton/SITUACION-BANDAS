# Reportes y activos
LOGO_PATH=assets/logo_artes_buho.jpg
OUTPUT_DIR=data/outputs
HISTORY_DIR=data/history
LOG_DIR=data/logs

# Drive (si no hay permisos, el sistema sigue en modo local)
DRIVE_REPORTS_ROOT=Informes
DRIVE_WEEKLY_FOLDER=InformeSemanal
DRIVE_MONTHLY_FOLDER=InformeMensual
DRIVE_ANNUAL_FOLDER=InformeAnual

# Correo (desactivado por defecto)
