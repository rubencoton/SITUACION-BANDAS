EMAIL_DRY_RUN_DEFAULT=true
EMAIL_PROVIDER=smtp
EMAIL_FROM=booking@artesbuhomanagement.com
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
